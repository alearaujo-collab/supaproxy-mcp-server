# SupaProxy base URL (the .NET Core API)
SUPAPROXY_BASE_URL=https://localhost:7001

# Default API key for stdio transport (when no header forwarding is available)
SUPAPROXY_API_KEY=your-api-key-here

# Default connection name for stdio transport
SUPAPROXY_CONNECTION_NAME=DefaultConnection

# AI / Anthropic — required for POST /ai/chat
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MAX_RETRIES=6
# Available models:
#   claude-haiku-4-5      → fast and cheap
#   claude-sonnet-4-6     → best quality (recommended)
#   claude-opus-4-6       → maximum capability
AI_MODEL=claude-haiku-4-5
AI_MAX_TOOL_ITERATIONS=10
AI_MAX_TOKENS=8192
